# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=BankingWorkflowSystem
APP_ENV=production
DEBUG=false

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=banking_workflow
POSTGRES_USER=banking_user
POSTGRES_PASSWORD=SecureBankingPass2024!
DATABASE_URL=postgresql+asyncpg://banking_user:SecureBankingPass2024!@db:5432/banking_workflow

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Workers ─────────────────────────────────────────────────────────────────
WORKERS=4
